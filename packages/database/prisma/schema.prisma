generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Query {
  id               String         @id @default(cuid())
  text             String
  category         String
  date_from        String
  date_to          String
  poly             String
  viz_hint         String
  createdAt        DateTime       @default(now())
  domain           String         @default("crime")
  resolved_location String?
  results          CrimeResult[]
  @@map("query")

}

model CrimeResult {
  id             String   @id @default(cuid())
  query_id       String
  persistent_id  String?
  category       String
  month          String
  street         String?
  latitude       Float?
  longitude      Float?
  outcome_category String?
  outcome_date   String?
  location_type  String?
  context        String?
  raw            Json?
  query          Query    @relation(fields: [query_id], references: [id])
  @@map("crime_results")

}

model SchemaVersion {
  id          String   @id @default(cuid())
  table_name  String
  column_name String
  column_type String
  triggered_by String
  createdAt   DateTime @default(now())
  domain      String   @default("crime")
  @@map("schema_version")
}